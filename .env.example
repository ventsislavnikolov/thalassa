# Neon Postgres connection string (Vercel Marketplace / Neon console).
# Local dev value lives in .env.local (gitignored).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Shared secret guarding GET /api/cron/scrape.
# Sent by the external cron (cron-job.org) as: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET="change-me"

# Deal-alert emails via Resend (optional). When all three are set, the cron run
# emails an alert when a watchlist entry crosses its target price / % drop.
# Leave unset to disable alerts (the cron still records prices).
# ALERT_EMAIL_FROM must be a Resend-verified sender.
RESEND_API_KEY=""
ALERT_EMAIL_FROM="alerts@yourdomain.com"
ALERT_EMAIL_TO="you@example.com"
